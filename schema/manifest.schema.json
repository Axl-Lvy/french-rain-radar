{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://radar.example.tld/schema/manifest.schema.json",
  "title": "Radar manifest",
  "description": "Manifest describing the currently available radar / nowcast / forecast frames. Clients render frames by substituting {timestamp}/{z}/{x}/{y} into each layer's tileUrlTemplate. The backend renders tiles lazily on first request.",
  "type": "object",
  "required": ["manifestVersion", "generatedAt", "bbox", "layers"],
  "additionalProperties": false,
  "properties": {
    "manifestVersion": {
      "type": "integer",
      "const": 2,
      "description": "Bump on breaking changes. Clients refuse incompatible versions. v2 = XYZ tile pyramid, lazy-rendered."
    },
    "generatedAt": {
      "type": "string",
      "format": "date-time",
      "description": "UTC ISO-8601 timestamp at which this manifest was written."
    },
    "bbox": {
      "type": "object",
      "required": ["latMin", "latMax", "lonMin", "lonMax"],
      "additionalProperties": false,
      "properties": {
        "latMin": { "type": "number", "minimum": -90, "maximum": 90 },
        "latMax": { "type": "number", "minimum": -90, "maximum": 90 },
        "lonMin": { "type": "number", "minimum": -180, "maximum": 180 },
        "lonMax": { "type": "number", "minimum": -180, "maximum": 180 }
      }
    },
    "colorScale": {
      "type": "string",
      "description": "Identifier of the colour ramp used to render the PNGs. Clients may use it to render a legend."
    },
    "layers": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "radar":    { "$ref": "#/$defs/layer" },
        "nowcast":  { "$ref": "#/$defs/layer" },
        "forecast": { "$ref": "#/$defs/layer" }
      }
    }
  },
  "$defs": {
    "layer": {
      "type": "object",
      "required": ["tileUrlTemplate", "minZoom", "maxZoom", "frames"],
      "additionalProperties": false,
      "properties": {
        "tileUrlTemplate": {
          "type": "string",
          "description": "Template with {timestamp}/{z}/{x}/{y} placeholders. E.g. 'radar/{timestamp}/{z}/{x}/{y}.png'."
        },
        "minZoom": { "type": "integer", "minimum": 0, "maximum": 20 },
        "maxZoom": { "type": "integer", "minimum": 0, "maximum": 20 },
        "runTime": {
          "type": "string",
          "format": "date-time",
          "description": "Reference time of the NWP run that produced this layer's frames (forecast layer only)."
        },
        "frames": {
          "type": "array",
          "items": { "$ref": "#/$defs/frame" }
        }
      }
    },
    "frame": {
      "type": "object",
      "required": ["timestamp"],
      "additionalProperties": false,
      "properties": {
        "timestamp": {
          "type": "string",
          "format": "date-time",
          "description": "UTC ISO-8601 timestamp the frame represents (valid time for forecast frames, observation time for radar)."
        }
      }
    }
  }
}
