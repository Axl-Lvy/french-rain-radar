# Copied to /etc/radar/env by install.sh. Read by systemd. Edit before first run.

# Météo-France API tokens from https://portail-api.meteofrance.fr/
# One per subscribed API. If a single portal Application is subscribed to
# both, paste the same apikey into both variables.
METEOFRANCE_TOKEN_AROME=
METEOFRANCE_TOKEN_RADAR=

# Region rendered into every tile pyramid. Defaults cover metropolitan
# France including Corsica.
RADAR_BBOX_LAT_MIN=41.3
RADAR_BBOX_LAT_MAX=51.5
RADAR_BBOX_LON_MIN=-5.5
RADAR_BBOX_LON_MAX=10.0

# Where the pipeline writes the manifest, source files, and cached tiles.
# Caddy is configured to serve this same path.
RADAR_TILE_DIR=/var/lib/radar/tiles

# How many hours of radar/forecast frames to keep before retention removes them.
RADAR_RETENTION_HOURS=12

# Colour ramp identifier (also written into the manifest).
RADAR_COLOR_SCALE=rainviewer-original

# XYZ zoom range advertised to clients. The tile server can lazily render any
# zoom the client requests, but max_zoom signals the boundary past which the
# underlying source resolution is exhausted.
RADAR_MIN_ZOOM=5
RADAR_MAX_ZOOM=10

# Tile-renderer service (loopback only; fronted by Caddy).
RADAR_TILE_SERVER_HOST=127.0.0.1
RADAR_TILE_SERVER_PORT=8765

LOG_LEVEL=INFO
