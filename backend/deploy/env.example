# Copied to /etc/radar/env by install.sh. Read by systemd. Edit before first run.

# Météo-France API tokens from https://portail-api.meteofrance.fr/
# One per subscribed API. If a single portal Application is subscribed to
# both, paste the same apikey into both variables.
METEOFRANCE_TOKEN_AROME=
METEOFRANCE_TOKEN_RADAR=

# Region rendered into every tile (default: Apt / Avignon area).
RADAR_BBOX_LAT_MIN=43.6
RADAR_BBOX_LAT_MAX=44.2
RADAR_BBOX_LON_MIN=4.6
RADAR_BBOX_LON_MAX=5.6

# Where the pipeline writes tiles + manifest.json.
# Caddy is configured to serve this same path.
RADAR_TILE_DIR=/var/lib/radar/tiles

# Tile dimensions (pixels). Larger = sharper at high zoom, more bandwidth.
RADAR_TILE_WIDTH=512
RADAR_TILE_HEIGHT=384

# How many hours of radar/nowcast/forecast frames to keep.
RADAR_RETENTION_HOURS=12

# Colour ramp identifier (also written into the manifest).
RADAR_COLOR_SCALE=rainviewer-original

LOG_LEVEL=INFO
