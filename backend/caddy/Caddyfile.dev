# Dev Caddyfile — HTTP only, no TLS, no rate-limit module dependency.
# Used by `make dev-caddy` via docker compose. Username / password: dev / dev.
#
# Same try-cache-then-render pattern as the production Caddyfile. The tile
# server runs on the host at 127.0.0.1:8765; docker compose forwards it via
# `host.docker.internal`.

{
    auto_https off
    admin off
}

:8080 {
    encode gzip

    basic_auth {
        # `dev` / `dev`  — generated with `caddy hash-password --plaintext dev`
        dev $2a$14$ojkB0gnt67yA9jaCFR0Vmu6jNJ4pkqRsR9bFNwzr5JaP5G7yZbZHe
    }

    @manifest path /manifest.json
    handle @manifest {
        root * /srv
        header Cache-Control "no-cache, max-age=5"
        file_server
    }

    @tile path_regexp tilepath ^/(radar|nowcast|forecast)/[^/]+/\d+/\d+/\d+\.png$
    handle @tile {
        root * /srv/cache
        header Cache-Control "public, max-age=60"

        @cached file
        handle @cached { file_server }
        reverse_proxy host.docker.internal:8765
    }
}
