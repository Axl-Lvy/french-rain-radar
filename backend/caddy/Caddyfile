# Production Caddyfile — installs to /etc/caddy/Caddyfile.
# Requires the caddy-ratelimit module (see backend/deploy/install.sh).
#
# Layout:
#   - /manifest.json         -> static file at /var/lib/radar/tiles/manifest.json
#   - /<layer>/<ts>/<z>/<x>/<y>.png
#         cache hit -> static file at /var/lib/radar/tiles/cache/<layer>/...
#         cache miss -> reverse_proxy to the tile-server (radar tile-server)
#                       which renders, writes the PNG to the cache, and returns it

{
    email axel.levy98@gmail.com
}

rain.axl-lvy.fr {
    encode gzip zstd

    # CORS: the Wasm client lives at https://axl-lvy.fr/rain and fetches
    # manifest.json + tiles cross-origin with a Basic-auth header. Browsers
    # send a preflight OPTIONS first (Authorization is a non-simple header);
    # we short-circuit it BEFORE basic_auth / rate_limit run, since the
    # preflight itself does not carry credentials.
    @cors_preflight method OPTIONS
    handle @cors_preflight {
        header {
            Access-Control-Allow-Origin "{http.request.header.Origin}"
            Access-Control-Allow-Methods "GET, OPTIONS"
            Access-Control-Allow-Headers "Authorization, Content-Type"
            Access-Control-Allow-Credentials "true"
            Access-Control-Max-Age "86400"
            Vary "Origin"
        }
        respond 204
    }

    # rate_limit runs before basic_auth (caddy-ratelimit hooks early). The
    # per_ip zone caps unauthenticated brute-force at 60 attempts / IP / min;
    # the per_user zone keeps the 1200 / user / min budget for legitimate
    # tile-heavy clients.
    rate_limit {
        zone per_ip {
            key {remote_host}
            events 600
            window 1m
        }
        zone per_user {
            key {http.auth.user.id}
            events 1200
            window 1m
        }
    }

    basic_auth {
        # Generate with:  caddy hash-password
        # Example below is a dummy hash; replace before deploy.
        alice $2a$14$REPLACE_WITH_REAL_BCRYPT_HASH...........................
    }

    header {
        Strict-Transport-Security "max-age=31536000; includeSubDomains"
        X-Content-Type-Options "nosniff"
        Referrer-Policy "no-referrer"
        # Echo the request Origin back so axl-lvy.fr/rain (and any other
        # cross-origin caller that has valid creds) can consume the API.
        # Basic_auth still gates real access — CORS just unlocks the browser.
        Access-Control-Allow-Origin "{http.request.header.Origin}"
        Access-Control-Allow-Credentials "true"
        Vary "Origin"
    }

    # Manifest: static, frequently updated.
    @manifest path /manifest.json
    handle @manifest {
        root * /var/lib/radar/tiles
        header Cache-Control "no-cache, max-age=10"
        file_server
    }

    # Tile path: try cache first, fall back to render service.
    @tile path_regexp tilepath ^/(radar|nowcast|forecast)/[^/]+/\d+/\d+/\d+\.png$
    handle @tile {
        root * /var/lib/radar/tiles/cache
        # Tile URLs are timestamp-scoped — same URL always returns the same
        # PNG. Cache aggressively so the client doesn't re-fetch as the user
        # scrubs back to a frame they've already seen.
        header Cache-Control "public, max-age=31536000, immutable"

        @cached file
        handle @cached {
            file_server
        }
        # Cache miss -> ask the tile server.
        reverse_proxy 127.0.0.1:8765 {
            header_up Host {host}
            transport http { keepalive 60s }
        }
    }

    log
}
