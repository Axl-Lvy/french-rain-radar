# Production Caddyfile — installs to /etc/caddy/Caddyfile.
# Requires the caddy-ratelimit module (see backend/deploy/install.sh).
#
# Layout:
#   - /manifest.json         -> static file at /var/lib/radar/tiles/manifest.json
#   - /<layer>/<ts>/<z>/<x>/<y>.png
#         cache hit -> static file at /var/lib/radar/tiles/cache/<layer>/...
#         cache miss -> reverse_proxy to the tile-server (radar tile-server)
#                       which renders, writes the PNG to the cache, and returns it

{
    email axel.levy98@gmail.com
}

radar.yourdomain.tld {
    encode gzip zstd

    basic_auth {
        # Generate with:  caddy hash-password
        # Example below is a dummy hash; replace before deploy.
        alice $2a$14$REPLACE_WITH_REAL_BCRYPT_HASH...........................
    }

    rate_limit {
        zone tiles {
            key {http.auth.user.id}
            events 1200
            window 1m
        }
    }

    # Manifest: static, frequently updated.
    @manifest path /manifest.json
    handle @manifest {
        root * /var/lib/radar/tiles
        header Cache-Control "no-cache, max-age=10"
        file_server
    }

    # Tile path: try cache first, fall back to render service.
    @tile path_regexp tilepath ^/(radar|nowcast|forecast)/[^/]+/\d+/\d+/\d+\.png$
    handle @tile {
        root * /var/lib/radar/tiles/cache
        header Cache-Control "public, max-age=300, immutable"

        @cached file
        handle @cached {
            file_server
        }
        # Cache miss -> ask the tile server.
        reverse_proxy 127.0.0.1:8765 {
            header_up Host {host}
            transport http { keepalive 60s }
        }
    }

    log
}
